# Supabase — Restaurant Central
# Copier en .env.local et remplir avec les valeurs de votre projet Supabase :
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Campay — Paiement Mobile Money (MTN / Orange)
# Inscription : https://demo.campay.net — Enregistrer une application, récupérer le jeton (CLÉS DE L'APPLICATION)
# Jeton permanent : section CLÉS DE L'APPLICATION de votre application (recommandé)
CAMPAY_TOKEN=votre_jeton_permanent
# Ou identifiants pour jeton temporaire :
# CAMPAY_APP_USERNAME=votre_app_username
# CAMPAY_APP_PASSWORD=votre_app_password
# DEV = sandbox, PROD = production
CAMPAY_ENVIRONMENT=DEV
# Optionnel : override de l’URL de l’API (laisser vide pour utiliser l’URL par défaut selon CAMPAY_ENVIRONMENT)
# CAMPAY_BASE_URL=https://api.campay.net
